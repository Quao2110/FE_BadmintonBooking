# Cấu hình API cho ứng dụng (Dùng với --dart-define-from-file)

# URL đầy đủ của Backend. Nếu để trống, ứng dụng sẽ tự dựa vào API_SCHEME và platform để tạo URL mặc định.
# Ví dụ: https://api.yourdomain.com
API_BASE_URL=

# Giao thức: https hoặc http (Mặc định là https nếu không khai báo)
API_SCHEME=https
